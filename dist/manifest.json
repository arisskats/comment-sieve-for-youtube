{
  "manifest_version": 3,
  "name": "Comment Sieve for YouTube",
  "short_name": "Comment Sieve",
  "version": "0.2.0",
  "description": "Filter YouTube watch-page comments locally with lightweight labels for spam, toxicity, questions, positive comments, and Greeklish.",
  "minimum_chrome_version": "114",
  "homepage_url": "https://github.com/arisskats/comment-sieve-for-youtube",
  "offline_enabled": true,
  "permissions": ["storage"],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://youtube.com/watch*"
      ],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ]
}
